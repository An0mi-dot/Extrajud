# ═══════════════════════════════════════════════════════════════
# EXTRATJUD - Variáveis de Ambiente (Exemplo)
# ═══════════════════════════════════════════════════════════════
# 
# INSTRUÇÕES:
# 1. Copie este arquivo e renomeie para .env (se necessário)
# 2. Configure as variáveis conforme seu ambiente
# 3. Este arquivo NOT deve ser versionado (git)
#
# ═══════════════════════════════════════════════════════════════

# NODE ENVIRONMENT
NODE_ENV=development

# SUPABASE (já configurado em public/assets/supabaseClient.js)
# SUPABASE_URL=https://seu-projeto.supabase.co
# SUPABASE_KEY=sua_chave_publica_aqui

# ELECTRON
ELECTRON_ENABLE_SECURITY_WARNINGS=false
# DEBUG=electron-main:*,automacao:*

# DESENVOLVIMENTO LOCAL
DEBUG_LEVEL=info
LOG_TO_FILE=false

# PROXY (se necessário)
# HTTP_PROXY=http://proxy.empresa.com:8080
# HTTPS_PROXY=http://proxy.empresa.com:8080

# ═══════════════════════════════════════════════════════════════
# Notas:
# • As credenciais Supabase estão em public/assets/supabaseClient.js
# • Configurações persistem em ~/.config/EXTRATJUD/ no Electron
# • Não commitar este arquivo com dados sensíveis
# ═══════════════════════════════════════════════════════════════
